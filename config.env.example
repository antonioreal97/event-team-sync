# Configurações do Banco de Dados
# Escolha entre PostgreSQL local ou Supabase
USE_SUPABASE=false

# Configurações PostgreSQL Local (quando USE_SUPABASE=false)
DATABASE_URL=postgresql://frela_user:frela_password@localhost:5432/frela_db
DB_USER=frela_user
DB_HOST=localhost
DB_NAME=frela_db
DB_PASSWORD=frela_password
DB_PORT=5432

# Configurações Supabase (quando USE_SUPABASE=true)
# Obtenha essas informações no painel do Supabase: https://supabase.com/dashboard
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Configurações da Aplicação
NODE_ENV=development
PORT=3000

# JWT Secret
JWT_SECRET=seu_jwt_secret_super_seguro_aqui

# Configurações de Email (para convites)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app

# URL da Aplicação
APP_URL=http://localhost:3000






